@page "/login"
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Components

@inject ITokenStorage storage
@inject NavigationManager nav

@inject HttpClient Http

<PageTitle>Login</PageTitle>

<div class="login-container">
    <div class="login-card">
        <h2>Welcome Back</h2>
        <p class="subtitle">Please sign in to continue</p>

        <div class="form-group">
            <label>Email</label>
            <InputText @bind-Value="loginRequest.Email" class="input" />
        </div>

        <div class="form-group">
            <label>Password</label>
            <InputText @bind-Value="loginRequest.Password" type="password" class="input" />
        </div>

        <button class="login-btn" @onclick="AttemptLogin">Login</button>
        <p>@error</p>

    </div>
</div>

@code {
    private LoginRequest loginRequest = new();
    private string? loginResponse;

    [Parameter]
    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    private string? error;

    public async Task AttemptLogin()
    {
        try
        {
            var response = await Http.PostAsJsonAsync("auth/login", loginRequest);

            if (response.IsSuccessStatusCode)
            {
                AuthResponse token = await response.Content.ReadFromJsonAsync<AuthResponse>();

                await storage.SetTokenAsync(token.Token);

                if (!string.IsNullOrWhiteSpace(ReturnUrl))
                {
                    nav.NavigateTo(ReturnUrl, forceLoad: true);
                }
                else
                {
                    nav.NavigateTo("/", forceLoad: true);
                }
            }
            else
            {
                error = "Failed Login";
            }
        }
        catch (Exception ex)
        {
            error = $"Error: {ex.Message}";
        }
    }

}
